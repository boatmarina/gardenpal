# Copy this file to .env and fill in your values.
# The app reads DATABASE_URL to connect to Supabase (PostgreSQL).
#
# Find your database password in:
#   Supabase dashboard → Project Settings → Database → Connection string
#
# Use the "URI" format and add ?sslmode=require at the end:
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.dgtaztizmbskrmvascqp.supabase.co:5432/postgres?sslmode=require

# Flask session secret — change this to something random in production
SECRET_KEY=change-me

# Optional: enable plant auto-fill features
# PERENUAL_API_KEY=
# OCR_SPACE_API_KEY=
# PLANT_ID_API_KEY=
