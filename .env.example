# Copy this file to .env and fill in your values.
# The app reads DATABASE_URL to connect to Supabase (PostgreSQL).
#
# Find your database password in:
#   Supabase dashboard → Project Settings → Database → Connection string
#
# Use the "URI" format (SSL is always on — no extra flag needed):
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.dgtaztizmbskrmvascqp.supabase.co:5432/postgres

# Flask session secret — change this to something random in production
SECRET_KEY=change-me

# Supabase Storage — for persistent image uploads
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# SUPABASE_STORAGE_BUCKET=garden-pal-images

# Optional: enable plant auto-fill features
# PERENUAL_API_KEY=
# OCR_SPACE_API_KEY=
# PLANT_ID_API_KEY=
